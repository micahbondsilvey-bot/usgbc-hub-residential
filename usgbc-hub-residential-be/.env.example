# ── App ─────────────────────────────────────────────────────────────
APP_PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:4200

# ── Database (Postgres via Docker Compose) ──────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=usgbc
DB_PASSWORD=usgbc
DB_NAME=usgbc_hub_residential
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT_MS=30000
DB_SYNCHRONIZE=true

# ── Redis (throttler storage) ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Auth / tokens ───────────────────────────────────────────────────
LOCAL_JWT_SECRET=change-me-in-real-envs
LOCAL_JWT_EXPIRES_IN=8h
LOCAL_JWT_ISSUER=usgbc-hub-residential-be
PASSWORD_RESET_TTL=1h
EMAIL_VERIFICATION_TTL=7d
INVITATION_TTL=7d
MOCK_AUTH=true

# ── Throttling (per-IP) ─────────────────────────────────────────────
THROTTLE_LOGIN_PER_MIN=10
THROTTLE_LOGIN_PER_HR=30
THROTTLE_RESET_PER_MIN=5
THROTTLE_RESET_PER_HR=20
THROTTLE_INVITE_ACCEPT_PER_MIN=10
THROTTLE_INVITE_ACCEPT_PER_HR=30

# ── Demo seed (email|password|globalRole ; separated) ───────────────
SEED_USERS=admin@residential.test|Admin123!|admin;team@residential.test|Team123!|user;rater@residential.test|Rater123!|user;reviewer@residential.test|Reviewer123!|user

# ── Property-based testing ──────────────────────────────────────────
FAST_CHECK_RUNS=100
# FAST_CHECK_SEED=   # deterministic seed in CI; absent locally → random + logged
